{
  "name": "agentic-engineering-v2",
  "private": true,
  "scripts": {
    "generate-dev-config": "node scripts/generate-dev-config.js",
    "prebuild": "npm run generate-dev-config",
    "build": "npx tsc -p tsconfig.frontend.json",

{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch:frontend",
      "type": "shell",
      "command": "npm",
      "args": ["run", "watch:frontend"],
      "isBackground": true,
      "problemMatcher": "$tsc-watch",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "group": "dev"
      }
    },
    {
      "label": "mock-oidc-provider",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "mock-oidc",
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Mock OIDC Provider",
          "endsPattern": "Listening on port"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}/mock-oidc-provider"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "group": "dev"
      }
    },
    {
      "label": "Start All",
      "dependsOn": [
        "watch:frontend",
        "mock-oidc-provider",
        "swa start"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "none",
        "isDefault": false
      }
    },
    {
      "label": "clean (functions)",
      "command": "dotnet",
      "args": [
        "clean",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "type": "process",
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/api"
      }
    },
    {
      "label": "build (functions)",
      "command": "dotnet",
      "args": [
        "build",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "type": "process",
      "dependsOn": "clean (functions)",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/api"
      }
    },
    {
      "label": "clean release (functions)",
      "command": "dotnet",
      "args": [
        "clean",
        "--configuration",
        "Release",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "type": "process",
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/api"
      }
    },
    {
      "label": "publish (functions)",
      "command": "dotnet",
      "args": [
        "publish",
        "--configuration",
        "Release",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "type": "process",
      "dependsOn": "clean release (functions)",
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/api"
      }
    },
    {
      "label": "swa start",
      "type": "shell",
      "command": "swa",
      "args": [
        "start"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "swa-cli",
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Welcome to Azure Static Web Apps CLI",
          "endsPattern": "Azure Static Web Apps emulator started at"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "close": true
      }
    },
    {
      "label": "swa stop",
      "type": "shell",
      "command": "pkill -TERM -f 'swa start' || true; pkill -TERM -f 'azurite' || true; sleep 1",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "close": true
      }
    },
    {
      "label": "swa restart",
      "type": "shell",
      "command": "swa start",
      "isBackground": true,
      "dependsOn": "swa stop",
      "problemMatcher": {
        "owner": "swa-cli-restart",
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Welcome to Azure Static Web Apps CLI",
          "endsPattern": "Azure Static Web Apps emulator started at"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "close": true
      }
    }
  ]
}
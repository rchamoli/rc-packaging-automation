{
  "globalHeaders": {
    "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-inline' https://*.azurestaticapps.net https://build.rapidcircle.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.azurestaticapps.net https://build.rapidcircle.com; frame-ancestors 'none';",
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "geolocation=(), microphone=(), camera=()"
  },
  "auth": {
    "rolesSource": "/api/roles",
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/cd41dae2-7921-4c3a-a9a3-56161d080b65/v2.0",
          "clientIdSettingName": "GRAPH_CLIENT_ID",
          "clientSecretSettingName": "GRAPH_CLIENT_SECRET"
        }
      }
    }
  },
  "routes": [
    {
      "route": "/.auth/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/roles",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/app/",
      "redirect": "/app/dashboard.html",
      "statusCode": 302
    },
    {
      "route": "/app/*",
      "allowedRoles": ["authenticated"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/api/manage/seed-sample",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/manage/seed-packaging-runs",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/demo/seed",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/demo/reset",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/health",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/app/*"]
  },
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/app/",
      "statusCode": 302
    }
  }
}
